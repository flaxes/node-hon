{
    "compilerOptions": {
        "module": "commonjs",
        "target": "esnext",
        "lib": ["esnext"],
        "resolveJsonModule": true,
        "checkJs": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": false,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "./build"
    },
    "include": [
        "src/**/*",
        "bin/**/*",
        "cli/**/*",
        "types/**/*",
        "test/**/*",
        "config.js",
        "test.js"
    ],
    "exclude": ["build"],
}
