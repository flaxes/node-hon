{
  "name": "flaks-node-hon",
  "version": "1.0.1",
  "description": "CommonJS Node.js client for hOn auth and air conditioner controls",
  "main": "src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/flaxes/node-hon"
  },
  "bin": {
    "node-hon": "bin/node-hon.js"
  },
  "files": [
    "bin/",
    "cli/",
    "src/",
    "presets/",
    "types/",
    "config_example.js",
    "README.md",
    "LICENSE"
  ],
  "type": "commonjs",
  "author": "Flaks",
  "engines": {
    "node": ">=23"
  },
  "scripts": {
    "test": "node --test \"test/*.test.js\"",
    "run-test-file": "node ./test",
    "typecheck": "tsc --noEmit --project jsconfig.json",
